      "name": "Auth",
      "item": [
        {
          "name": "Login - Operator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token_operator', res.token);",
                  "  console.log('Token Operator salvo!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos.operador@aguiabranca.com.br\",\n  \"password\": \"nest123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
