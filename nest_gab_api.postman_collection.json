            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Eficiência Energética 2025 - Atualizado\",\n  \"content\": \"Priorizar iniciativas que reduzam o consumo energético da frota em pelo menos 20% até o final de 2025.\"\n}"
